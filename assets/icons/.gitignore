# Generated assets that aren't part of the desktop build — only needed
# by web (favicon) and mobile (iOS/Android) consumers. Regenerated on
# demand by `python generate.py`.
favicon/
ios/
android/

# Mac noise inside the iconset directory
.DS_Store

# AppIcon.icns is built from the iconset by `iconutil` during the macOS
# build, so we don't track the generated bundle. Source PNGs in
# AppIcon.iconset/ are tracked.
macos/AppIcon.icns

# Platform icons used by the desktop build (macos/, linux/, windows/)
# are committed artifacts — re-render from master.svg by running
# `python generate.py` on a machine with rsvg-convert and commit the
# changes.
