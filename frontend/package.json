{
  "name": "finzytrack-frontend",
  "version": "0.1.0",
  "description": "Finzytrack Frontend - Privacy-focused personal finance application",
  "type": "module",
  "scripts": {
    "predev": "npm run generate-recipe-types",
    "prebuild": "npm run generate-recipe-types",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint . --fix",
    "format": "prettier --write src/",
    "test": "vitest",
    "test:run": "vitest run",
    "generate-api": "npx openapi-typescript-codegen --input http://localhost:8001/openapi.json --output ./src/services/generated-api",
    "generate-recipe-types": "node scripts/generate-recipe-types.mjs"
  },
  "dependencies": {
    "@headlessui/vue": "^1.7.22",
    "@heroicons/vue": "^2.1.5",
    "@tanstack/vue-table": "^8.21.3",
    "@tanstack/vue-virtual": "^3.13.12",
    "decimal.js": "^10.6.0",
    "echarts": "^6.0.0",
    "events": "^3.3.0",
    "monaco-editor": "^0.54.0",
    "ofx-js": "^0.2.0",
    "papaparse": "^5.5.3",
    "uuid": "^13.0.0",
    "vue": "^3.4.0",
    "vue-echarts": "^8.0.1",
    "vue-router": "^4.4.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@esbuild-plugins/node-globals-polyfill": "^0.2.3",
    "@esbuild-plugins/node-modules-polyfill": "^0.2.2",
    "@rushstack/eslint-patch": "^1.12.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/papaparse": "^5.5.2",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.43.0",
    "@typescript-eslint/parser": "^8.43.0",
    "@vitejs/plugin-vue": "^5.1.0",
    "@vue/eslint-config-prettier": "^9.0.0",
    "@vue/test-utils": "^2.4.6",
    "buffer": "^6.0.3",
    "eslint": "^8.57.0",
    "eslint-plugin-vue": "^9.27.0",
    "happy-dom": "^20.8.9",
    "json-schema-to-typescript": "^15.0.4",
    "openapi-typescript-codegen": "^0.29.0",
    "prettier": "^3.3.0",
    "stream-browserify": "^3.0.0",
    "tailwindcss": "^4.2.2",
    "timers-browserify": "^2.0.12",
    "util": "^0.12.5",
    "vite": "^5.4.0",
    "vite-plugin-monaco-editor": "^1.1.0",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
