;; Small test ledger: ~20 transactions across 5 accounts
;; Covers basic CRUD testing

option "operating_currency" "USD"

1970-01-01 open Assets:Bank:Checking       USD
1970-01-01 open Assets:Bank:Savings        USD
1970-01-01 open Liabilities:CreditCard     USD
1970-01-01 open Income:Salary              USD
1970-01-01 open Expenses:Food              USD
1970-01-01 open Expenses:Rent              USD
1970-01-01 open Expenses:Transport         USD
1970-01-01 open Expenses:Unknown           USD
1970-01-01 open Equity:Opening-Balances    USD

1970-01-01 commodity USD

2024-01-01 * "Opening Balance"
  Assets:Bank:Checking        5000.00 USD
  Equity:Opening-Balances    -5000.00 USD

