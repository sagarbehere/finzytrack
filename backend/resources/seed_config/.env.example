# Environment variables for FinzyTrack
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# These variables are referenced in email rule files using ${VAR_NAME} syntax.
# The .env file is loaded automatically on startup — no need to export manually.

# IMAP credentials for email import
# IMAP_USERNAME=user@example.com
# IMAP_PASSWORD=app-specific-password
